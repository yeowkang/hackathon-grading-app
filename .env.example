# Upstash Redis - Required for data persistence
# These are auto-set when you add the Redis integration in Vercel Storage.
# For local dev: copy from the Upstash console (REST API section).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin panel password - REQUIRED, set this in Vercel Environment Variables
ADMIN_PASSWORD=
